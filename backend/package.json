{
  "name": "gcg-deckbuilder-backend",
  "private": true,
  "scripts": {
    "dev": "bun --env-file .env.local --hot src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "migrate": "bun --env-file .env.local db/migrate.ts",
    "migrate:prod": "bun db/migrate.ts",
    "seed": "bun --env-file .env.local db/seed.ts",
    "seed:prod": "bun db/seed.ts",
    "coverage": "bun --env-file .env.local scripts/resolverCoverage.ts"
  },
  "dependencies": {
    "@graphql-tools/load-files": "^7",
    "@graphql-tools/schema": "^10",
    "dataloader": "^2",
    "elysia": "^1.4.28",
    "graphql": "^16",
    "graphql-yoga": "^5",
    "kysely": "^0.27",
    "pg": "^8"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5",
    "@graphql-codegen/typescript": "^4",
    "@graphql-codegen/typescript-resolvers": "^4",
    "@types/pg": "^8",
    "bun-types": "^1.3.12",
    "typescript": "^5"
  }
}
